############################################################
# LAIR - Local AI Intelligence Router
# Environment Configuration Template
#
# Copy this file to ".env" and customize values as needed.
############################################################

############################################################
# Application
############################################################

APP_NAME=LAIR
APP_VERSION=0.2.0-alpha

############################################################
# Logging
############################################################

LOG_LEVEL=INFO

############################################################
# API
############################################################

HOST=127.0.0.1
PORT=8000

############################################################
# Providers
############################################################

DEFAULT_PROVIDER=lmstudio

LM_STUDIO_URL=http://localhost:1234/v1
OLLAMA_URL=http://localhost:11434
VLLM_URL=

############################################################
# Models
############################################################

DEFAULT_MODEL=

############################################################
# Request Settings
############################################################

REQUEST_TIMEOUT=300

############################################################
# Routing
############################################################

ENABLE_CAPABILITY_ROUTING=true
ENABLE_EXPLAINABILITY=true
ENABLE_BENCHMARKS=true

############################################################
# Development
############################################################

DEBUG=false

############################################################
# Future Providers
############################################################

OPENAI_API_KEY=
ANTHROPIC_API_KEY=